<!DOCTYPE html>
<html>
  <head>
    <title>The Collection — Victorian Novels</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
    <style>
      body { background: #faf9f7; }
      .page-header { background: #f5f0e8; border-bottom: 1px solid #e0d8cc; padding: 2.5rem 0; }
      .page-header h1 { font-family: 'Playfair Display', serif; font-weight: 400; color: #2c2416; }
      .page-header p { font-style: italic; color: #6b5d4f; margin: 0; }
      .novel-card { background: #fff; border: 1px solid #e8e0d4; border-radius: 12px; padding: 1.25rem; height: 100%; display: flex; flex-direction: column; transition: border-color 0.2s; }
      .novel-card:hover { border-color: #c4b49a; }
      .novel-card h5 { font-family: 'Playfair Display', serif; font-weight: 500; color: #2c2416; }
      .genre-badge { font-size: 11px; letter-spacing: 0.05em; padding: 3px 8px; border-radius: 6px; background: #f5f0e8; color: #6b5d4f; border: 1px solid #e0d4c0; display: inline-block; }
      .card-divider { width: 24px; height: 1px; background: #e0d4c0; margin: 0.5rem 0; }
      .card-desc { font-size: 13px; color: #6b5d4f; line-height: 1.6; flex: 1; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
      .btn-victorian { background: #2c2416; color: #fff; border: none; font-size: 13px; padding: 0.4rem 1rem; border-radius: 6px; }
      .btn-victorian:hover { background: #4a3d2a; color: #fff; }
    </style>
  </head>
  <body>

    <%- include('../partials/navbar') %>

    <!-- Page header -->
    <div class="page-header">
      <div class="container">
        <h1>The Collection</h1>
        <p><%= novels.length %> novels from the Victorian era — 1837 to 1901</p>
      </div>
    </div>

    <!-- Novel grid -->
    <div class="container py-5">
      <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        <% novels.forEach(novel => { %>
          <div class="col">
            <div class="novel-card">
              <span class="genre-badge"><%= novel.genre %></span>
              <h5 class="mt-2 mb-0"><%= novel.title %></h5>
              <p class="text-muted small mb-0"><%= novel.author %></p>
              <p class="text-muted small"><%= novel.year %></p>
              <div class="card-divider"></div>
              <p class="card-desc"><%= novel.description %></p>
              <div class="mt-3 d-flex justify-content-between align-items-center">
                <a href="/novels/<%= novel._id %>" class="btn btn-victorian">Read more</a>
                <% if (currentUser && currentUser.username === process.env.ADMIN_USERNAME) { %>
                  <div class="d-flex gap-2">
                    <a href="/novels/<%= novel._id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <form action="/novels/<%= novel._id %>?_method=DELETE" method="POST">
                      <button class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                  </div>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>