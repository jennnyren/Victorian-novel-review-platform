<!DOCTYPE html>
<html>
  <head>
    <title><%= novel.title %> — Victorian Novels</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
    <style>
      body { background: #faf9f7; }
      .novel-hero { background: #f5f0e8; border-bottom: 1px solid #e0d8cc; padding: 3rem 0; }
      .novel-title { font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 400; color: #2c2416; }
      .novel-author { font-family: 'Playfair Display', serif; font-style: italic; color: #6b5d4f; }
      .novel-desc { color: #4a3d2a; line-height: 1.8; }
      .genre-badge { font-size: 11px; letter-spacing: 0.05em; padding: 3px 8px; border-radius: 6px; background: #fff; color: #6b5d4f; border: 1px solid #e0d4c0; }
      .section-title { font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 500; color: #2c2416; padding-bottom: 0.5rem; border-bottom: 1px solid #e0d4c0; margin-bottom: 1rem; }
      .review-card { background: #fff; border: 1px solid #e8e0d4; border-radius: 12px; padding: 1.25rem; margin-bottom: 1rem; }
      .stars { color: #c4a35a; font-size: 14px; }
      .form-card { background: #fff; border: 1px solid #e8e0d4; border-radius: 12px; padding: 1.5rem; }
      .btn-victorian { background: #2c2416; color: #fff; border: none; width: 100%; padding: 0.6rem; border-radius: 6px; font-size: 14px; }
      .btn-victorian:hover { background: #4a3d2a; color: #fff; }
      .card-divider { width: 24px; height: 1px; background: #e0d4c0; margin: 0.75rem 0; }
    </style>
  </head>
  <body>

    <%- include('../partials/navbar') %>

    <!-- Novel hero -->
    <div class="novel-hero">
      <div class="container" style="max-width: 720px;">
        <span class="genre-badge"><%= novel.genre %></span>
        <h1 class="novel-title mt-2"><%= novel.title %></h1>
        <p class="novel-author">by <%= novel.author %></p>
        <div class="d-flex gap-3 text-muted small mb-3">
          <span>📅 <%= novel.year %></span>
          <span>💬 <%= novel.reviews.length %> review<%= novel.reviews.length !== 1 ? 's' : '' %></span>
        </div>
        <div class="card-divider"></div>
        <p class="novel-desc"><%= novel.description %></p>

        <!-- Admin controls -->
        <% if (currentUser && currentUser.username === process.env.ADMIN_USERNAME) { %>
          <div class="d-flex gap-2 mt-3">
            <a href="/novels/<%= novel._id %>/edit" class="btn btn-sm btn-outline-secondary">Edit novel</a>
            <form action="/novels/<%= novel._id %>?_method=DELETE" method="POST">
              <button class="btn btn-sm btn-outline-danger">Delete novel</button>
            </form>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Reviews + form — single column -->
    <div class="container py-5" style="max-width: 720px;">

      <!-- Reviews -->
      <p class="section-title">Reviews</p>

      <% if (novel.reviews.length === 0) { %>
        <p class="text-muted fst-italic mb-4">No reviews yet — be the first to share your thoughts.</p>
      <% } %>

      <% novel.reviews.forEach(review => { %>
        <div class="review-card">
          <div class="d-flex justify-content-between align-items-center mb-1">
            <span class="fw-500 small"><%= review.author ? review.author.username : 'Unknown' %></span>
            <span class="text-muted" style="font-size: 12px;"><%= review.createdAt.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' }) %></span>
          </div>
          <div class="stars">
            <% for (let i = 1; i <= 5; i++) { %>
              <%= i <= review.rating ? '★' : '☆' %>
            <% } %>
          </div>
          <p class="small mt-1 mb-0" style="color: #4a3d2a; line-height: 1.6;"><%= review.body %></p>

          <!-- Edit/Delete only for review author -->
          <% if (currentUser && review.author && review.author._id.equals(currentUser._id)) { %>
            <div class="d-flex gap-2 mt-2">
              <a href="/novels/<%= novel._id %>/reviews/<%= review._id %>/edit" class="btn btn-sm btn-outline-secondary" style="font-size: 12px;">Edit</a>
              <form action="/novels/<%= novel._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                <button class="btn btn-sm btn-outline-danger" style="font-size: 12px;">Delete</button>
              </form>
            </div>
          <% } %>
        </div>
      <% }) %>

      <!-- Leave a review form -->
      <div class="mt-5">
        <p class="section-title">Leave a review</p>
        <% if (currentUser) { %>
          <div class="form-card">
            <form action="/novels/<%= novel._id %>/reviews" method="POST">
              <div class="mb-3">
                <label class="form-label small text-muted">Rating</label>
                <select name="rating" class="form-select form-select-sm">
                  <option value="5">★★★★★ — Excellent</option>
                  <option value="4">★★★★☆ — Very good</option>
                  <option value="3">★★★☆☆ — Good</option>
                  <option value="2">★★☆☆☆ — Fair</option>
                  <option value="1">★☆☆☆☆ — Poor</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label small text-muted">Your review</label>
                <textarea name="body" class="form-control form-control-sm" rows="4" placeholder="Share your thoughts on this novel..." required></textarea>
              </div>
              <button type="submit" class="btn btn-victorian">Submit review</button>
            </form>
          </div>
        <% } else { %>
          <div class="form-card text-center">
            <p class="text-muted small mb-3">You need to be logged in to leave a review.</p>
            <a href="/login" class="btn btn-victorian">Login to review</a>
          </div>
        <% } %>
      </div>

    </div>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>