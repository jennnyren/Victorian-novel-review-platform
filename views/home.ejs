<!DOCTYPE html>
<html>
  <head>
    <title>Victorian Novels</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
    <style>
      body { font-family: 'Segoe UI', sans-serif; background: #faf9f7; }
      .hero { background: #f5f0e8; border-bottom: 1px solid #e0d8cc; padding: 5rem 2rem 4rem; text-align: center; }
      .hero-title { font-family: 'Playfair Display', serif; font-size: 3rem; font-weight: 400; color: #2c2416; }
      .hero-subtitle { font-family: 'Playfair Display', serif; font-style: italic; font-size: 1.2rem; color: #6b5d4f; }
      .era-badge { font-size: 13px; letter-spacing: 0.15em; color: #9c8b7a; }
      .era-badge::before, .era-badge::after { content: '——'; margin: 0 0.5rem; }
      .feature-card { background: #fff; border: 1px solid #e8e0d4; border-radius: 12px; padding: 1.5rem; text-align: center; height: 100%; }
      .feature-card h5 { font-family: 'Playfair Display', serif; font-weight: 500; }
      .btn-victorian { background: #2c2416; color: #fff; border: none; padding: 0.75rem 2rem; border-radius: 8px; }
      .btn-victorian:hover { background: #4a3d2a; color: #fff; }
      .btn-outline-victorian { border: 1px solid #2c2416; color: #2c2416; padding: 0.75rem 2rem; border-radius: 8px; background: transparent; }
      .btn-outline-victorian:hover { background: #2c2416; color: #fff; }
    </style>
  </head>
  <body>

    <%- include('partials/navbar') %>

    <!-- Hero -->
    <div class="hero">
      <p class="era-badge">1837 — 1901</p>
      <h1 class="hero-title">Victorian Novels</h1>
      <p class="hero-subtitle mb-4">Discover the literature that defined an era</p>
      <a href="/novels" class="btn btn-victorian me-2">Browse the Collection</a>
      <% if (!currentUser) { %>
        <a href="/register" class="btn btn-outline-victorian">Join to Review</a>
      <% } %>
    </div>

    <!-- Feature cards -->
    <div class="container py-5">
      <div class="row g-4">
        <div class="col-md-4">
          <div class="feature-card">
            <div class="fs-2 mb-3">📚</div>
            <h5>Curated collection</h5>
            <p class="text-muted small">15 essential novels from Dickens, Hardy, Brontë, and more</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="feature-card">
            <div class="fs-2 mb-3">✍️</div>
            <h5>Leave reviews</h5>
            <p class="text-muted small">Share your thoughts and read what others have to say</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="feature-card">
            <div class="fs-2 mb-3">⭐</div>
            <h5>Rate books</h5>
            <p class="text-muted small">Rate each novel from 1 to 5 and track your favourites</p>
          </div>
        </div>
      </div>
    </div>

    <%- include('partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>